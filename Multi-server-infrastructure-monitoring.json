      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst server1 = items[0].json;\nconst server2 = items[1].json;\nconst server3 = items[2].json;\n\nconst content = `You are an infrastructure monitoring assistant. Analyze the health data from three servers and write a professional consolidated infrastructure report in 4-5 paragraphs. Compare the servers, highlight any concerning values (memory above 80%, disk above 85%, CPU above 80%), and recommend any actions needed.\\n\\nServer 1 (Main Server) - ${server1.hostname}:\\n- CPU: ${server1.cpu_usage_percent}\\n- Memory: ${server1.memory.used_mb}MB / ${server1.memory.total_mb}MB (${server1.memory.usage_percent}% used)\\n- Disk: ${server1.disk}\\n- Uptime: ${server1.uptime}\\n\\nServer 2 (Web Server) - ${server2.hostname}:\\n- CPU: ${server2.cpu_usage_percent}\\n- Memory: ${server2.memory.used_mb}MB / ${server2.memory.total_mb}MB (${server2.memory.usage_percent}% used)\\n- Disk: ${server2.disk}\\n- Uptime: ${server2.uptime}\\n\\nServer 3 (DB Server) - ${server3.hostname}:\\n- CPU: ${server3.cpu_usage_percent}\\n- Memory: ${server3.memory.used_mb}MB / ${server3.memory.total_mb}MB (${server3.memory.usage_percent}% used)\\n- Disk: ${server3.disk}\\n- Uptime: ${server3.uptime}`;\n\nreturn [{\n  json: {\n    model: \"llama-3.3-70b-versatile\",\n    max_tokens: 1500,\n    temperature: 0.4,\n    messages: [{ role: \"user\", content: content }]\n  }\n}];"
      },
