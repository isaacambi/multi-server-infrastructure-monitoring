    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\n\nconst raw = response.choices[0].message.content;\n\nconst summary = raw\n  .replace(/\\*\\*(.*?)\\*\\*/g, '$1')\n  .replace(/#{1,6}\\s/g, '')\n  .replace(/\\*(.*?)\\*/g, '$1')\n  .trim();\n\nconst allItems = $('Merge').all();\n\nconst isCritical = allItems.some(item => \n  item.json.memory?.usage_percent > 85 ||\n  item.json.disk?.includes('100%') ||\n  parseFloat(item.json.cpu_usage_percent) > 80\n);\n\nreturn [{\n  json: {\n    summary: summary,\n    is_critical: isCritical,\n    is_critical_type: typeof isCritical,\n    is_critical_string: String(isCritical),\n    timestamp: new Date().toLocaleString('en-GB', { timeZone: 'Africa/Lagos' }),\n    servers_monitored: 3\n  }\n}];"
      },
